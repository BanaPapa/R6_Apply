# ── Supabase (naver-kb 기존 인스턴스 재사용) ──────────────────
# 대시보드 → Settings → API 에서 복사. 실제 값은 .env 에 넣으세요 (.env 는 gitignore됨).
# 미설정 시 앱은 순수 실시간 크롤(아카이브 비활성)로 그대로 동작합니다.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ingest 전용 — 클라이언트 노출 금지(VITE_ 접두사 금지).
# 서버사이드(Vite 플러그인/Vercel 함수)의 크롤러가 청약 아카이브 기록에 사용.
# Vercel 배포본은 Vercel 환경변수로 동일 키 설정.
# SUPABASE_SERVICE_ROLE_KEY=

# ── 공공데이터포털(odcloud) 한국부동산원 청약홈 OpenAPI ──────────
# 청약홈은 목록을 롤링 ~5년만 노출. 그보다 과거 데이터(분양정보 ~2020-02+, 경쟁률·
# 당첨가점·특별공급 신청현황 ~2021+)는 운영기관(한국부동산원)이 odcloud 로 공개하며,
# 이 키로 받아와 과거 조회를 메운다. 미설정 시 과거 폴백만 비활성(현재 5년은 정상).
# 발급: data.go.kr → 아래 3개 서비스 활용신청 후 마이페이지 인증키.
#   - 청약홈 분양정보 조회 서비스 (ApplyhomeInfoDetailSvc)
#   - 청약홈 청약접수 경쟁률 및 특별공급 신청현황 조회 서비스 (ApplyhomeInfoCmpetRtSvc)
#   - 청약홈 청약 신청·당첨자 정보 조회 서비스 (ApplyhomeStatSvc, 통계/시각화용)
ODCLOUD_SERVICE_KEY=

# 로깅 레벨 (info | warn | error)
LOG_LEVEL=info
